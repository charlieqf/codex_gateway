{
  "name": "codex-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "postinstall": "node scripts/patch-codex-sdk-stdin-epipe.mjs",
    "dev:gateway": "npm --workspace @codex-gateway/gateway run dev",
    "dev:admin": "npm --workspace @codex-gateway/admin-cli run dev",
    "probe:codex": "npm --workspace @codex-gateway/provider-codex run probe --"
  },
  "devDependencies": {
    "@emnapi/core": "^1.11.2",
    "@emnapi/runtime": "^1.11.2",
    "@types/node": "^25.6.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=24"
  },
  "overrides": {
    "fast-uri": "3.1.3"
  }
}
