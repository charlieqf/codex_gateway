NODE_ENV=production
GATEWAY_AUTH_MODE=credential
GATEWAY_REQUIRE_ENTITLEMENT=1
GATEWAY_ALLOW_EMPTY_UPSTREAM_POOL=0
GATEWAY_API_KEY_ENCRYPTION_SECRET=replace-with-production-research-llm-random-secret
GATEWAY_LOG_LEVEL=info

# Research generation uses only the reviewed direct GoldenCode/GLM-5.2 pool.
# The registry currently enables Aliyun at concurrency 3; Qianfan and Tencent
# remain disabled rollback entries after repeated long-fragment timeouts.
MEDCODE_PUBLIC_MODEL_ID=goldencode
MEDCODE_PUBLIC_MODELS_JSON_FILE=/etc/codex-gateway/research-production-goldencode.json
MEDCODE_QIANFAN_API_KEY_FILE=/run/secrets/research_production_qianfan_api_key
MEDCODE_TENCENT_TOKENHUB_API_KEY_FILE=/run/secrets/research_production_tencent_api_key
MEDCODE_ALIYUN_DASHSCOPE_API_KEY_FILE=/run/secrets/research_production_aliyun_api_key
MEDCODE_QIANFAN_TIMEOUT_MS=900000
MEDCODE_TENCENT_TOKENHUB_TIMEOUT_MS=900000
MEDCODE_ALIYUN_TOKEN_PLAN_TIMEOUT_MS=900000
