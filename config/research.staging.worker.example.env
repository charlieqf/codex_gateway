# Copy to research.staging.worker.env on an isolated host. Secret values are
# mounted as Docker secrets and must never be placed in this file.
NODE_ENV=staging
# compose.research-staging.yml overrides this with the explicit host-side
# RESEARCH_STAGING_WORKER_ENABLED switch. The checked-in default stays closed.
RESEARCH_WORKER_ENABLED=false
RESEARCH_WORKER_ID=research-staging-worker-1
RESEARCH_WORKER_VERSION=doctor-research-skill.1.6.3
RESEARCH_WORKER_CONCURRENCY=1
RESEARCH_POLL_INTERVAL_MS=1000
RESEARCH_DRAIN_TIMEOUT_SECONDS=30
RESEARCH_LEASE_SECONDS=120
RESEARCH_LEASE_RENEW_SECONDS=30
RESEARCH_HEARTBEAT_SECONDS=15
RESEARCH_HEARTBEAT_STALE_SECONDS=45
RESEARCH_RECONCILE_INTERVAL_SECONDS=60
RESEARCH_RECONCILE_BATCH_SIZE=100
RESEARCH_CLEANUP_INTERVAL_SECONDS=3600
RESEARCH_CLEANUP_BATCH_SIZE=100
RESEARCH_ORPHAN_GRACE_SECONDS=3600
RESEARCH_BACKUP_INTERVAL_SECONDS=3600
RESEARCH_BACKUP_MAX_AGE_SECONDS=7200
RESEARCH_BACKUP_RETENTION_COUNT=24
RESEARCH_EMBEDDED_MAINTENANCE_ENABLED=false
RESEARCH_BACKUP_TARGET_ENCRYPTION_CONFIRMED=false

RESEARCH_MAX_DAILY_RUNS_PER_SUBJECT=2
RESEARCH_MAX_UNIQUE_DOCTORS_PER_SUBJECT_30D=5
RESEARCH_MAX_QUEUED_RUNS=5
RESEARCH_MAX_NEEDS_INPUT_PER_SUBJECT=2
RESEARCH_IDEMPOTENCY_REPLAY_SECONDS=604800
RESEARCH_IDEMPOTENCY_TOMBSTONE_SECONDS=2592000
RESEARCH_RESULT_TTL_SECONDS=2592000
RESEARCH_ARTIFACT_TTL_SECONDS=2592000
RESEARCH_RUN_RETENTION_SECONDS=7776000
RESEARCH_NEEDS_INPUT_TTL_SECONDS=259200
RESEARCH_MAX_CHECKPOINT_BYTES=1048576
RESEARCH_MAX_RESULT_BYTES=4194304
RESEARCH_MAX_ARTIFACT_BYTES=1048576
RESEARCH_MAX_ARTIFACT_BYTES_PER_RUN=4194304
RESEARCH_MAX_STORAGE_BYTES=1073741824
RESEARCH_MIN_FREE_BYTES=1073741824
RESEARCH_MIN_FREE_PERCENT=10

RESEARCH_NCBI_EMAIL=
RESEARCH_NCBI_API_KEY_FILE=
RESEARCH_CROSSREF_MAILTO=
RESEARCH_ORCID_MODE=anonymous
RESEARCH_ORCID_ANONYMOUS_USE_APPROVED=false
RESEARCH_ORCID_BEARER_TOKEN_FILE=
RESEARCH_ORCID_CLIENT_ID_FILE=
RESEARCH_ORCID_CLIENT_SECRET_FILE=
# Direct mode requires one to three doctor.official_profile_urls values on
# every create request; the Gateway rejects URLs outside this exact allowlist.
RESEARCH_WEB_SEARCH_PROVIDER=direct
RESEARCH_WEB_SEARCH_API_KEY_FILE=
RESEARCH_OFFICIAL_WEB_ALLOWED_DOMAINS=shsmu.edu.cn,pumch.cn,qk.sjtu.edu.cn
RESEARCH_MAX_OFFICIAL_RESULTS=5
RESEARCH_MAX_PUBLICATIONS=40
RESEARCH_MIN_REFERENCES=3
RESEARCH_ADAPTER_TIMEOUT_MS=20000
RESEARCH_MAX_ADAPTER_JSON_BYTES=2000000
RESEARCH_MAX_SOURCE_BYTES=1000000
RESEARCH_MAX_EXTERNAL_RESPONSE_BYTES_PER_CALL=2000000
RESEARCH_MAX_SOURCE_TEXT_CHARACTERS=200000
RESEARCH_EXTERNAL_USER_AGENT=codex-gateway-doctor-research-staging/1.0

# The service credential is issued with an exact one-model allowlist matching
# this public model ID.
RESEARCH_LLM_MODEL=goldencode
# Explicitly override the GoldenCode pool default so structured Research
# generation has a bounded latency/token profile. Missing or invalid values
# fail Worker startup.
RESEARCH_LLM_REASONING_EFFORT=low
RESEARCH_LLM_ALLOWED_HOSTS=gateway
RESEARCH_LLM_BEARER_TOKEN_FILE=/run/secrets/research_llm_bearer
RESEARCH_LLM_TIMEOUT_MS=240000
RESEARCH_MAX_LLM_RESPONSE_BYTES=2000000
RESEARCH_MAX_LLM_CALLS_PER_RUN=4
RESEARCH_SYNTHESIS_SHARD_COUNT=3
RESEARCH_MAX_INPUT_TOKENS_PER_CALL=120000
RESEARCH_MAX_INPUT_TOKENS_PER_RUN=480000
RESEARCH_MAX_OUTPUT_TOKENS_PER_RUN=200000
RESEARCH_MAX_OUTPUT_TOKENS_PER_CALL=18000
RESEARCH_MAX_EXTERNAL_REQUESTS_PER_RUN=908
RESEARCH_MAX_EXTERNAL_BYTES_PER_RUN=1816000000
RESEARCH_HARD_DEADLINE_SECONDS=570

RESEARCH_MIN_REVIEW_CONTENT=6000
RESEARCH_MAX_QUESTION_CONTENT=80
RESEARCH_MIN_ANSWER_CONTENT=80
RESEARCH_MAX_ANSWER_CONTENT=800
RESEARCH_FORBIDDEN_OUTPUT_FRAGMENTS=ignore all prior instructions,reveal api key,system prompt
