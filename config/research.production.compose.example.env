# Copy to config/research.production.compose.env on the production host.
# The real file is ignored by git and must remain mode 0600.
RESEARCH_PRODUCTION_API_ENV_FILE=./config/research.production.api.env
RESEARCH_PRODUCTION_LLM_GATEWAY_ENV_FILE=./config/research.production.llm-gateway.env
RESEARCH_PRODUCTION_WORKER_ENV_FILE=./config/research.production.worker.env
RESEARCH_PRODUCTION_QIANFAN_KEY_FILE=./secrets/research-production-qianfan-key
RESEARCH_PRODUCTION_TENCENT_KEY_FILE=./secrets/research-production-tencent-key
RESEARCH_PRODUCTION_ALIYUN_KEY_FILE=./secrets/research-production-aliyun-key
RESEARCH_PRODUCTION_LLM_TOKEN_FILE=./secrets/research-production-llm-token

# Production admission and both background processes remain closed until the
# ordered bootstrap checks in the production runbook pass.
RESEARCH_PRODUCTION_API_ENABLED=false
RESEARCH_PRODUCTION_WORKER_ENABLED=false
RESEARCH_PRODUCTION_MAINTENANCE_ENABLED=false
