# Copy to research.staging.gateway.env on an isolated host. This file is not a
# production enablement file and contains no usable credentials.
NODE_ENV=staging
GATEWAY_AUTH_MODE=credential
GATEWAY_REQUIRE_ENTITLEMENT=1
GATEWAY_ALLOW_EMPTY_UPSTREAM_POOL=0
GATEWAY_API_KEY_ENCRYPTION_SECRET=replace-with-staging-only-random-secret
GATEWAY_LOG_LEVEL=info
CODEX_HOME=/var/lib/codex-gateway/codex-home
CODEX_WORKDIR=/app
CODEX_SKIP_GIT_REPO_CHECK=1

# Configure the same staging-only upstream/model settings used by the normal
# Gateway. Do not copy production user credentials or production API keys.
MEDCODE_PUBLIC_MODEL_ID=medcode
MEDCODE_UPSTREAM_MODEL=replace-with-reviewed-staging-upstream-model

# Research API is controlled by the explicit host-side staging switch in
# compose.research-staging.yml.
RESEARCH_CONTROL_READ_RPM=30
RESEARCH_CONTROL_MUTATION_RPM=10
RESEARCH_ACCEPT_WHEN_WORKER_UNAVAILABLE=false
RESEARCH_HEARTBEAT_STALE_SECONDS=45
RESEARCH_MAX_DAILY_RUNS_PER_SUBJECT=2
RESEARCH_MAX_UNIQUE_DOCTORS_PER_SUBJECT_30D=5
RESEARCH_MAX_QUEUED_RUNS=5
RESEARCH_MAX_NEEDS_INPUT_PER_SUBJECT=2
RESEARCH_MAX_CHECKPOINT_BYTES=1048576
RESEARCH_MAX_RESULT_BYTES=4194304
RESEARCH_MAX_ARTIFACT_BYTES=1048576
RESEARCH_MAX_STORAGE_BYTES=1073741824
RESEARCH_MIN_FREE_BYTES=1073741824
RESEARCH_MIN_FREE_PERCENT=10
RESEARCH_BACKUP_MAX_AGE_SECONDS=7200
RESEARCH_IDEMPOTENCY_REPLAY_SECONDS=604800
RESEARCH_IDEMPOTENCY_TOMBSTONE_SECONDS=2592000
RESEARCH_RESULT_TTL_SECONDS=2592000
RESEARCH_RUN_RETENTION_SECONDS=7776000
RESEARCH_NEEDS_INPUT_TTL_SECONDS=259200
