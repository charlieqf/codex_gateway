NODE_ENV=development
GATEWAY_AUTH_MODE=dev
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8787

GATEWAY_SQLITE_PATH=.gateway-state/gateway.db
GATEWAY_CLIENT_EVENTS_SQLITE_PATH=.gateway-state/client-events.db
GATEWAY_CLIENT_EVENTS_RPM=60
GATEWAY_CLIENT_EVENTS_RPD=2000
# Doctor Research remains disabled until its separate database, limits and
# release gates are configured. Every blank value below is required when the
# feature flag is enabled.
RESEARCH_API_ENABLED=false
RESEARCH_DB_PATH=
RESEARCH_ARTIFACT_ROOT=
RESEARCH_CONTROL_READ_RPM=
RESEARCH_CONTROL_MUTATION_RPM=
RESEARCH_ACCEPT_WHEN_WORKER_UNAVAILABLE=false
RESEARCH_HEARTBEAT_STALE_SECONDS=45
RESEARCH_MAX_DAILY_RUNS_PER_SUBJECT=
RESEARCH_MAX_UNIQUE_DOCTORS_PER_SUBJECT_30D=
RESEARCH_MAX_QUEUED_RUNS=
RESEARCH_MAX_NEEDS_INPUT_PER_SUBJECT=
RESEARCH_MAX_CHECKPOINT_BYTES=1048576
RESEARCH_MAX_RESULT_BYTES=4194304
RESEARCH_MAX_ARTIFACT_BYTES=1048576
RESEARCH_MAX_STORAGE_BYTES=
RESEARCH_MIN_FREE_BYTES=
RESEARCH_MIN_FREE_PERCENT=
RESEARCH_BACKUP_MAX_AGE_SECONDS=
# All finite TTLs are required when the Research API is enabled.
RESEARCH_IDEMPOTENCY_REPLAY_SECONDS=
RESEARCH_IDEMPOTENCY_TOMBSTONE_SECONDS=
RESEARCH_RESULT_TTL_SECONDS=
RESEARCH_RUN_RETENTION_SECONDS=
RESEARCH_NEEDS_INPUT_TTL_SECONDS=
# Optional read-only admin browser UI/API for client messages.
GATEWAY_ADMIN_MESSAGES_AUTH=token
GATEWAY_ADMIN_MESSAGES_TOKEN=
# Optional local billing admin API token for /gateway/admin/billing/v1/*.
# Keep this in trusted backend/operator secret storage only.
GATEWAY_BILLING_ADMIN_TOKEN=
GATEWAY_BILLING_ADMIN_TOKEN_NEXT=
GATEWAY_BILLING_ADMIN_RPM=120
GATEWAY_BILLING_ADMIN_RPD=10000
GATEWAY_BILLING_ADMIN_CONCURRENT=8
# Optional v2 internal provisioning endpoint used by billing subject creation.
# Set both BASE_URL and TOKEN to enable POST /gateway/admin/billing/v1/subjects.
GATEWAY_UPSTREAM_V2_BASE_URL=
GATEWAY_UPSTREAM_V2_TOKEN=
GATEWAY_UPSTREAM_V2_TIMEOUT_MS=5000
# Required by admin CLI issue/rotate/reveal-key. Keep stable; losing it makes
# encrypted full API keys unrecoverable.
GATEWAY_API_KEY_ENCRYPTION_SECRET=change-me-local-api-key-secret
CODEX_HOME=.gateway-state/codex-home
# Optional multi-account pool config. When set, each configured account uses
# its own codexHome and CODEX_HOME remains only a single-account fallback.
GATEWAY_UPSTREAM_ACCOUNTS_JSON=
# Diagnostics/maintenance only. Allows startup with no selectable upstream
# account so provider routes can return subscription_unavailable.
GATEWAY_ALLOW_EMPTY_UPSTREAM_POOL=0
CODEX_WORKDIR=.
CODEX_SKIP_GIT_REPO_CHECK=0
MEDCODE_UPSTREAM_MODEL=gpt-5.6-sol
MEDCODE_UPSTREAM_REASONING_EFFORT=medium
MEDCODE_PUBLIC_MODEL_ID=medcode
GATEWAY_NATIVE_SESSION_PUBLIC_MODEL_ID=
MEDCODE_PUBLIC_MODEL_CONTEXT_WINDOW=400000
MEDCODE_PUBLIC_MODEL_MAX_CONTEXT_WINDOW=400000
MEDCODE_PUBLIC_MODEL_MAX_OUTPUT_TOKENS=128000
# Optional multi-model registry. File path takes precedence over inline JSON.
# Default behavior with both unset is a single enabled public model: medcode.
MEDCODE_PUBLIC_MODELS_JSON_FILE=
MEDCODE_PUBLIC_MODELS_JSON=
# Optional OpenRouter runtime for enabled registry models such as expert/pro/standard.
MEDCODE_OPENROUTER_API_KEY=
MEDCODE_OPENROUTER_API_KEY_FILE=
MEDCODE_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MEDCODE_OPENROUTER_SITE_URL=
MEDCODE_OPENROUTER_APP_TITLE=MedCode
MEDCODE_OPENROUTER_TIMEOUT_MS=600000
# Optional Baidu Qianfan Token Plan runtime for enabled registry models.
MEDCODE_QIANFAN_API_KEY=
MEDCODE_QIANFAN_API_KEY_FILE=
MEDCODE_QIANFAN_BASE_URL=https://qianfan.baidubce.com/v2/tokenplan/team
MEDCODE_QIANFAN_TIMEOUT_MS=600000
MEDCODE_ALIYUN_DASHSCOPE_API_KEY=
MEDCODE_ALIYUN_DASHSCOPE_API_KEY_FILE=
MEDCODE_ALIYUN_TOKEN_PLAN_BASE_URL=https://token-plan.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
MEDCODE_ALIYUN_TOKEN_PLAN_ANTHROPIC_BASE_URL=https://token-plan.cn-beijing.maas.aliyuncs.com/apps/anthropic
MEDCODE_ALIYUN_TOKEN_PLAN_TIMEOUT_MS=600000
MEDCODE_TENCENT_TOKENHUB_API_KEY=
MEDCODE_TENCENT_TOKENHUB_API_KEY_FILE=
MEDCODE_TENCENT_TOKENHUB_BASE_URL=https://tokenhub.tencentmaas.com/plan/v3
MEDCODE_TENCENT_TOKENHUB_TIMEOUT_MS=600000

# Optional image generation. Without account-pool image binding, the top-level
# MEDCODE_IMAGE_OPENAI_API_KEY is used. With imageApiKeyEnv fields in
# GATEWAY_UPSTREAM_ACCOUNTS_JSON, set one env var per image-capable account.
MEDCODE_IMAGE_GENERATION_ENABLED=0
MEDCODE_IMAGE_OPENAI_API_KEY=
MEDCODE_IMAGE_OPENAI_API_KEY_A=
MEDCODE_IMAGE_OPENAI_API_KEY_B=
MEDCODE_IMAGE_OPENAI_BASE_URL=
MEDCODE_IMAGE_TIMEOUT_MS=180000
# Optional: used only after an upstream image billing hard-limit error.
# This fallback key is expected to call gpt-image-1.5, not gpt-image-2.
MEDCODE_IMAGE_BILLING_FALLBACK_OPENAI_API_KEY=
MEDCODE_IMAGE_BILLING_FALLBACK_OPENAI_BASE_URL=
MEDCODE_IMAGE_BILLING_FALLBACK_MODEL=gpt-image-1.5
MEDCODE_IMAGE_BILLING_FALLBACK_TIMEOUT_MS=180000
# Optional secret file with extra fallback lines in provider:key format.
# Supported providers: openai, xai, gemini.
MEDCODE_IMAGE_BILLING_FALLBACK_KEYS_FILE=
MEDCODE_IMAGE_BILLING_FALLBACK_OPENAI_MODEL=gpt-image-1.5
MEDCODE_IMAGE_BILLING_FALLBACK_XAI_MODEL=grok-imagine-image-quality
MEDCODE_IMAGE_BILLING_FALLBACK_XAI_RESOLUTION=1k
MEDCODE_IMAGE_BILLING_FALLBACK_GEMINI_MODEL=gemini-3.1-flash-image
MEDCODE_IMAGE_BILLING_FALLBACK_GEMINI_IMAGE_SIZE=1K
# End-to-end Gateway image request cap. Keep below Nginx/client disconnect time
# so slow upstream image calls return a structured 504 upstream_timeout.
MEDCODE_IMAGE_REQUEST_TIMEOUT_MS=180000

# Local development only. Do not set this in production.
GATEWAY_DEV_ACCESS_TOKEN=change-me-dev-token

GATEWAY_LOG_LEVEL=info
