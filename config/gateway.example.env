NODE_ENV=development
GATEWAY_AUTH_MODE=dev
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8787

GATEWAY_SQLITE_PATH=.gateway-state/gateway.db
GATEWAY_CLIENT_EVENTS_SQLITE_PATH=.gateway-state/client-events.db
GATEWAY_CLIENT_EVENTS_RPM=60
GATEWAY_CLIENT_EVENTS_RPD=2000
# Required by admin CLI issue/rotate/reveal-key. Keep stable; losing it makes
# encrypted full API keys unrecoverable.
GATEWAY_API_KEY_ENCRYPTION_SECRET=change-me-local-api-key-secret
CODEX_HOME=.gateway-state/codex-home
CODEX_WORKDIR=.
CODEX_SKIP_GIT_REPO_CHECK=0
MEDCODE_UPSTREAM_MODEL=gpt-5.5
MEDCODE_UPSTREAM_REASONING_EFFORT=high
MEDCODE_PUBLIC_MODEL_ID=medcode
MEDCODE_PUBLIC_MODEL_CONTEXT_WINDOW=400000
MEDCODE_PUBLIC_MODEL_MAX_CONTEXT_WINDOW=400000
MEDCODE_PUBLIC_MODEL_MAX_OUTPUT_TOKENS=128000

# Local development only. Do not set this in production.
GATEWAY_DEV_ACCESS_TOKEN=change-me-dev-token

GATEWAY_LOG_LEVEL=info
