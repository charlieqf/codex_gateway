NODE_ENV=production
GATEWAY_AUTH_MODE=credential
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8787
GATEWAY_SQLITE_PATH=/var/lib/codex-gateway/gateway.db
CODEX_HOME=/var/lib/codex-gateway/codex-home
CODEX_WORKDIR=/app
CODEX_SKIP_GIT_REPO_CHECK=1
MEDCODE_UPSTREAM_MODEL=gpt-5.4
MEDCODE_UPSTREAM_REASONING_EFFORT=medium
MEDCODE_PUBLIC_MODEL_ID=medcode
MEDCODE_PUBLIC_MODEL_CONTEXT_WINDOW=272000
MEDCODE_PUBLIC_MODEL_MAX_CONTEXT_WINDOW=1000000
MEDCODE_PUBLIC_MODEL_MAX_OUTPUT_TOKENS=128000
GATEWAY_LOG_LEVEL=info
GATEWAY_PUBLIC_SERVICE_NAME=medcode
GATEWAY_PUBLIC_PROVIDER_NAME=medcode
GATEWAY_PUBLIC_PROVIDER_DISPLAY_NAME=MedCode
GATEWAY_PUBLIC_SUBSCRIPTION_ID=medcode
GATEWAY_PUBLIC_PHASE=controlled-trial

# Used only if compose.edge.example.yml is explicitly reviewed and enabled.
GATEWAY_DOMAIN=gateway.example.com
GATEWAY_PUBLIC_BASE_URL=https://gateway.example.com
